{
  "name": "speakist-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",

    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:preview": "pnpm pages:build && wrangler pages dev",
    "deploy:dev": "pnpm pages:build && wrangler pages deploy .vercel/output/static --project-name speakist-dev --branch dev",
    "deploy:prod": "pnpm pages:build && wrangler pages deploy .vercel/output/static --project-name speakist-prod --branch main",

    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply speakist-dev --local",
    "db:migrate:dev": "wrangler d1 migrations apply speakist-dev --remote",
    "db:migrate:prod": "wrangler d1 migrations apply speakist-prod --remote",
    "db:studio": "drizzle-kit studio",
    "db:seed:local": "wrangler d1 execute speakist-dev --local --file=scripts/seed.sql",
    "db:seed:dev": "wrangler d1 execute speakist-dev --remote --file=scripts/seed.sql"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^0.454.0",
    "next": "^15.0.2",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0-rc-02c0cdc852-20240822",
    "react-dom": "^19.0.0-rc-02c0cdc852-20240822",
    "resend": "^4.0.0",
    "stripe": "^17.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^22.8.1",
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vercel": "^37.14.0",
    "wrangler": "^3.84.0"
  },
  "overrides": {
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1"
  }
}
