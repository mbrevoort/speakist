{
  "name": "speakist-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build --env dev",
    "cf:preview": "opennextjs-cloudflare preview --env dev",
    "deploy:dev": "NEXT_PUBLIC_SITE_URL=https://speakist-dev.brevoortstudio.com opennextjs-cloudflare build --env dev && opennextjs-cloudflare deploy --env dev",
    "deploy:prod": "NEXT_PUBLIC_SITE_URL=https://speakist.ai opennextjs-cloudflare build --env production && opennextjs-cloudflare deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply speakist-dev --local --env dev",
    "db:migrate:dev": "wrangler d1 migrations apply speakist-dev --remote --env dev",
    "db:migrate:prod": "wrangler d1 migrations apply speakist-prod --remote --env production",
    "db:studio": "drizzle-kit studio",
    "db:seed:local": "wrangler d1 execute speakist-dev --local --env dev --file=scripts/seed.sql",
    "db:seed:dev": "wrangler d1 execute speakist-dev --remote --env dev --file=scripts/seed.sql",
    "db:seed:prod": "wrangler d1 execute speakist-prod --remote --env production --file=scripts/seed.sql",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.2",
    "@opennextjs/cloudflare": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.454.0",
    "next": "^15.0.2",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0-rc-02c0cdc852-20240822",
    "react-dom": "^19.0.0-rc-02c0cdc852-20240822",
    "resend": "^4.0.0",
    "stripe": "^17.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.8.1",
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.0.0"
  },
  "overrides": {
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1"
  }
}
