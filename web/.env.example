# -----------------------------------------------------------------------------
# Speakist web — environment template
# -----------------------------------------------------------------------------
# Copy to .env.local for local dev. Production secrets go into Cloudflare via:
#   wrangler pages secret put <NAME> --project-name speakist-dev
#   wrangler pages secret put <NAME> --project-name speakist-prod
#
# Phase 1 needs: NEXT_PUBLIC_SITE_URL + AUTH_SECRET. Everything else is
# optional until the phase that uses it.

# ---------- App ----------
# Base URL Next.js uses in metadata + the magic-link URL generation.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bootstrap super-admin email. Seed script promotes this account.
SUPER_ADMIN_EMAIL=mike@brevoort.com

# ---------- Auth.js ----------
# Required. 32+ random bytes. Generate: openssl rand -base64 33
AUTH_SECRET=

# Optional in dev (defaults to request origin). Required for Cloudflare Pages
# production deploys — set to the full https:// URL of your prod site.
# AUTH_URL=https://speakist.ai

# ---------- Email (Resend) ----------
# Required to actually send magic-link emails. In dev, leave blank and the
# link is logged to `wrangler dev` console instead — no email account needed.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@speakist.brevoort.com

# ---------- App-layer encryption (Phase 5) ----------
# 32+ byte base64 string for encrypting Deepgram keys at rest.
# Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# ---------- Stripe (Phase 4) ----------
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- Deepgram (Phase 6) ----------
# Project ID from https://console.deepgram.com/ → Settings → API Keys.
DEEPGRAM_PROJECT_ID=
# API key with `keys:write` scope — mints short-lived keys for Mac sessions.
DEEPGRAM_PROJECT_KEY=
