<?xml version="1.0" encoding="utf-8"?>
<!--
  Speakist update feed. Read by Sparkle in the Mac app; the SUFeedURL in
  project.yml points at the `/appcast.xml` path served from this file.

  Each release appends an <item> block inside <channel>, newest first.
  scripts/release.sh prints the exact fragment to paste after building.

  Sparkle validates:
    * sparkle:edSignature  — EdDSA signature from sign_update
    * sparkle:version       — build number (integer, monotonic)
    * sparkle:shortVersionString — user-facing version
    * sparkle:minimumSystemVersion — macOS gate
    * enclosure.url         — DMG download URL (stable)
    * enclosure.length      — DMG size in bytes (for progress UI)

  See: https://sparkle-project.org/documentation/publishing/
-->
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     version="2.0">
  <channel>
    <title>Speakist</title>
    <link>https://speakist.ai/appcast.xml</link>
    <description>Speakist for macOS — update feed</description>
    <language>en</language>

    <!--
      New <item> blocks go HERE (above any existing ones).
      scripts/release.sh prints a ready-to-paste block after a successful
      build.
    -->

  </channel>
</rss>
