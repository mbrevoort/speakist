<?xml version="1.0" encoding="utf-8"?>
<!--
  Speakist DEV channel. Used by builds produced with
  `make release CHANNEL=dev` (SUFeedURL = speakist-dev.brevoortstudio.com/
  appcast-dev.xml). Only dev-channel installs poll this feed — stable
  and beta users never see these releases.

  Dev-channel appcast is hosted on the dev Worker, so dev releases can
  ship without touching prod:
      1. scripts/release.sh 0.2.0 --channel dev --publish
      2. edit this file, paste the <item> block
      3. cd web && pnpm deploy:dev

  Each release appends an <item> block inside <channel>, newest first.
-->
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     version="2.0">
  <channel>
    <title>Speakist (dev)</title>
    <link>https://speakist-dev.brevoortstudio.com/appcast-dev.xml</link>
    <description>Speakist for macOS — dev channel update feed</description>
    <language>en</language>

    <!-- New <item> blocks go HERE (above any existing ones). -->

  </channel>
</rss>
