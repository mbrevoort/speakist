# -----------------------------------------------------------------------------
# Speakist web — environment template
# -----------------------------------------------------------------------------
# Copy to .env.local for local dev; set the same vars in Vercel for prod.
# Every required var has a line explaining where it comes from.
#
# Phase 1 (scaffold) only strictly needs the NEXT_PUBLIC_SUPABASE_* and
# SUPABASE_SERVICE_ROLE_KEY vars to boot. Stripe / Deepgram / Resend go in
# Phases 4 and 6.

# ---------- App ----------
# Base URL Next.js uses in metadata/og tags. Use localhost in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bootstrap super-admin email. The seed script promotes this account.
SUPER_ADMIN_EMAIL=mike@brevoort.com

# 32+ byte base64 string for encrypting Deepgram keys at rest.
# Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# ---------- Supabase ----------
# From Supabase dashboard → Project Settings → API.
# Local dev: `supabase start` prints these; use the "API URL" and "anon key".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Same page, "service_role secret". Server-only. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Stripe (Phase 4) ----------
# From https://dashboard.stripe.com/test/apikeys — use test keys in dev.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# (the CLI prints a "Your webhook signing secret is whsec_..." line).
STRIPE_WEBHOOK_SECRET=

# ---------- Deepgram (Phase 6) ----------
# Project ID from https://console.deepgram.com/ → Settings → API Keys.
DEEPGRAM_PROJECT_ID=
# A Deepgram API key with the `keys:write` scope — it's used server-side to
# mint short-lived keys for individual Mac sessions. Never leaves the server.
DEEPGRAM_PROJECT_KEY=

# ---------- Resend (Phase 3) ----------
# Transactional email (invitations, receipts).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@speakist.brevoort.com
